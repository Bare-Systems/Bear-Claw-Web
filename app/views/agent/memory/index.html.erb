<% content_for :title, "Memory — Agent — BearClaw" %>

<div class="max-w-4xl mx-auto space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-white mb-1">Memory</h1>
    <p class="text-gray-500 text-sm">Facts, preferences, and context the BearClaw agent has stored.</p>
  </div>

  <% if @entries.any? %>
    <div class="space-y-3">
      <% @entries.each do |entry| %>
        <% type_class = case entry["type"]
           when "user"      then "bg-sky-950 text-sky-300 border-sky-800/60"
           when "feedback"  then "bg-amber-950 text-amber-300 border-amber-800/60"
           when "project"   then "bg-violet-950 text-violet-300 border-violet-800/60"
           when "reference" then "bg-teal-950 text-teal-300 border-teal-800/60"
           else                  "bg-gray-800 text-gray-400 border-gray-700"
           end %>
        <div class="flex items-start justify-between gap-4 rounded-xl border border-gray-800 bg-gray-900/60 px-5 py-4">
          <div class="flex items-start gap-3 min-w-0">
            <span class="mt-0.5 shrink-0 rounded-full border px-2 py-0.5 text-xs font-medium capitalize <%= type_class %>">
              <%= entry["type"] || "unknown" %>
            </span>
            <div class="min-w-0">
              <p class="text-sm font-semibold text-white truncate"><%= entry["name"] %></p>
              <p class="mt-0.5 text-xs text-gray-400"><%= entry["description"] %></p>
              <% if entry["content"].present? %>
                <p class="mt-2 text-xs text-gray-500 leading-relaxed line-clamp-3"><%= entry["content"] %></p>
              <% end %>
            </div>
          </div>
          <div class="shrink-0 flex flex-col items-end gap-2">
            <% if entry["created_at"].present? %>
              <span class="text-xs text-gray-600"><%= ursa_time_ago(entry["created_at"]) %></span>
            <% end %>
            <%= button_to "Delete", agent_memory_path(entry["id"]), method: :delete,
                  class: "text-xs text-red-400 hover:text-red-300 transition cursor-pointer",
                  form: { data: { turbo_confirm: "Delete memory entry \"#{entry["name"]}\"?" } } %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-xl border border-dashed border-gray-700 bg-gray-900/40 px-6 py-12 text-center">
      <p class="text-sm font-medium text-gray-300">No memory entries</p>
      <p class="mt-1 text-sm text-gray-500">The agent stores facts here as it learns about your environment.</p>
    </div>
  <% end %>
</div>
