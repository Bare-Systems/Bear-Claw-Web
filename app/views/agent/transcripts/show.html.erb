<% content_for :title, "Transcript ##{@transcript["id"]} — Agent — BearClaw" %>

<div class="mx-auto max-w-6xl space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div>
      <%= link_to "← Back to Transcripts", agent_transcripts_path, class: "text-sm text-gray-500 transition hover:text-gray-300" %>
      <h1 class="mt-2 text-2xl font-bold text-white">Transcript #<%= @transcript["id"] %></h1>
      <p class="mt-1 text-sm text-gray-500">Tardigrade edge request and response capture after transcript redaction.</p>
    </div>
    <% if @transcript["response_status"].present? %>
      <span class="rounded-full px-3 py-1.5 text-xs font-medium <%= bearclaw_run_status_classes(@transcript["response_status"].to_i >= 400 ? "error" : "done") %>">
        <%= @transcript["response_status"] %>
      </span>
    <% end %>
  </div>

  <% if @error_message.present? %>
    <section class="rounded-2xl border border-amber-800/60 bg-amber-950/30 p-6">
      <h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-amber-300">Tardigrade Unavailable</h2>
      <p class="mt-2 text-sm leading-6 text-amber-100"><%= @error_message %></p>
      <p class="mt-2 text-sm text-amber-200/80">The transcript shell stayed up, but the edge artifact could not be fetched.</p>
    </section>
  <% else %>
    <section class="grid gap-4 md:grid-cols-4">
      <div class="rounded-2xl border border-gray-800 bg-gray-900/70 p-4">
        <p class="text-[11px] uppercase tracking-[0.18em] text-gray-500">Captured</p>
        <p class="mt-2 text-sm text-white"><%= bearclaw_transcript_timestamp(@transcript["ts_ms"]) %></p>
      </div>
      <div class="rounded-2xl border border-gray-800 bg-gray-900/70 p-4">
        <p class="text-[11px] uppercase tracking-[0.18em] text-gray-500">Scope</p>
        <p class="mt-2 text-sm text-white"><%= @transcript["scope"] %></p>
      </div>
      <div class="rounded-2xl border border-gray-800 bg-gray-900/70 p-4">
        <p class="text-[11px] uppercase tracking-[0.18em] text-gray-500">Identity</p>
        <p class="mt-2 text-sm text-white break-all"><%= @transcript["identity"].presence || "anonymous" %></p>
      </div>
      <div class="rounded-2xl border border-gray-800 bg-gray-900/70 p-4">
        <p class="text-[11px] uppercase tracking-[0.18em] text-gray-500">Client IP</p>
        <p class="mt-2 text-sm text-white"><%= @transcript["client_ip"].presence || "—" %></p>
      </div>
    </section>

    <section class="grid gap-4 lg:grid-cols-2">
      <article class="rounded-3xl border border-gray-800 bg-gray-900/60 p-5">
        <h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-300">Request</h2>
        <dl class="mt-4 space-y-3 text-sm">
          <div>
            <dt class="text-gray-500">Route</dt>
            <dd class="mt-1 text-white break-all"><%= @transcript["route"] %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Upstream URL</dt>
            <dd class="mt-1 text-white break-all"><%= @transcript["upstream_url"] %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Correlation ID</dt>
            <dd class="mt-1 text-white break-all"><%= @transcript["correlation_id"] %></dd>
          </div>
        </dl>
        <pre class="mt-4 overflow-x-auto rounded-2xl border border-gray-800 bg-black/30 p-4 text-xs leading-6 text-gray-200"><%= bearclaw_transcript_body(@transcript["request_body"]) %></pre>
      </article>

      <article class="rounded-3xl border border-gray-800 bg-gray-900/60 p-5">
        <h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-300">Response</h2>
        <dl class="mt-4 space-y-3 text-sm">
          <div>
            <dt class="text-gray-500">Content Type</dt>
            <dd class="mt-1 text-white break-all"><%= @transcript["response_content_type"].presence || "—" %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Status</dt>
            <dd class="mt-1 text-white"><%= @transcript["response_status"] %></dd>
          </div>
        </dl>
        <pre class="mt-4 overflow-x-auto rounded-2xl border border-gray-800 bg-black/30 p-4 text-xs leading-6 text-gray-200"><%= bearclaw_transcript_body(@transcript["response_body"]) %></pre>
      </article>
    </section>
  <% end %>
</div>
