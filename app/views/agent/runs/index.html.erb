<% content_for :title, "Runs — Agent — BearClaw" %>

<div class="mx-auto max-w-6xl space-y-6">
  <div class="flex items-end justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-white">Runs</h1>
      <p class="mt-1 text-sm text-gray-500">Recent BearClaw executions, grouped by run id and operator identity.</p>
    </div>
    <%= link_to "Open Chat", agent_chat_index_path, class: "rounded-full border border-white/10 px-4 py-2 text-sm text-gray-300 transition hover:border-white/20 hover:text-white" %>
  </div>

  <% if @error_message.present? %>
    <section class="rounded-2xl border border-amber-800/60 bg-amber-950/30 p-6">
      <h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-amber-300">BearClaw Unavailable</h2>
      <p class="mt-2 max-w-2xl text-sm leading-6 text-amber-100"><%= @error_message %></p>
      <p class="mt-2 text-sm text-amber-200/80">The page is still available, but live run data could not be loaded.</p>
    </section>
  <% elsif @runs.any? %>
    <section class="overflow-hidden rounded-2xl border border-gray-800 bg-gray-900/70">
      <table class="w-full text-sm">
        <thead class="border-b border-gray-800 bg-black/20 text-gray-500">
          <tr>
            <th class="px-4 py-3 text-left font-medium">Run</th>
            <th class="px-4 py-3 text-left font-medium">Status</th>
            <th class="px-4 py-3 text-left font-medium">Started</th>
            <th class="px-4 py-3 text-left font-medium">User</th>
            <th class="px-4 py-3 text-left font-medium">Events</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <% @runs.each do |run| %>
            <tr class="hover:bg-white/[0.03]">
              <td class="px-4 py-4">
                <div class="font-medium text-white"><%= run["id"] %></div>
                <% if run["device_id"].present? %>
                  <div class="mt-1 text-xs text-gray-500"><%= run["device_id"] %></div>
                <% end %>
              </td>
              <td class="px-4 py-4">
                <span class="rounded-full px-2.5 py-1 text-xs font-medium <%= bearclaw_run_status_classes(run["status"]) %>"><%= run["status"] %></span>
              </td>
              <td class="px-4 py-4 text-gray-300"><%= bearclaw_run_timestamp(run["started_at"]) %></td>
              <td class="px-4 py-4 text-gray-300"><%= run["user_id"] %></td>
              <td class="px-4 py-4 text-gray-400"><%= run["event_count"] %></td>
              <td class="px-4 py-4 text-right">
                <%= link_to "Open", agent_run_path(run["id"]), class: "rounded-full border border-white/10 px-3 py-1.5 text-xs text-gray-300 transition hover:border-white/20 hover:text-white" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>
  <% else %>
    <section class="rounded-2xl border border-dashed border-gray-700 bg-gray-900/40 px-6 py-12 text-center">
      <p class="text-sm font-medium text-gray-200">No runs yet</p>
      <p class="mt-2 text-sm text-gray-500">Start a BearClaw chat request and the execution trace will appear here.</p>
    </section>
  <% end %>
</div>
