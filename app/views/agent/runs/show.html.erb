<% content_for :title, "Run #{@run["id"]} — Agent — BearClaw" %>
<% live_run = @error_message.blank? && @run["status"].to_s == "in_progress" %>

<div
  class="mx-auto max-w-6xl space-y-6"
  data-controller="run-stream"
  data-run-stream-live-value="<%= live_run %>"
  data-run-stream-replay-value="<%= live_run %>"
  data-run-stream-url-value="<%= live_run ? stream_agent_run_path(@run["id"]) : "" %>"
>
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div>
      <%= link_to "← Back to Runs", agent_runs_path, class: "text-sm text-gray-500 transition hover:text-gray-300" %>
      <h1 class="mt-2 text-2xl font-bold text-white"><%= @run["id"] %></h1>
      <p class="mt-1 text-sm text-gray-500">Run artifact timeline with redacted tool traffic and operator identity context.</p>
    </div>
    <div class="flex items-center gap-3">
      <span class="rounded-full px-3 py-1.5 text-xs font-medium <%= bearclaw_run_status_classes(@run["status"]) %>" data-run-stream-target="status">
        <%= @run["status"] || "unknown" %>
      </span>
      <span class="rounded-full border border-white/10 bg-black/20 px-3 py-1.5 text-xs text-gray-400" data-run-stream-target="state">
        <%= live_run ? "Connecting live stream…" : "Static artifact" %>
      </span>
    </div>
  </div>

  <% if @error_message.present? %>
    <section class="rounded-2xl border border-amber-800/60 bg-amber-950/30 p-6">
      <h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-amber-300">BearClaw Unavailable</h2>
      <p class="mt-2 text-sm leading-6 text-amber-100"><%= @error_message %></p>
      <p class="mt-2 text-sm text-amber-200/80">The run page stayed up, but the upstream run artifact could not be fetched.</p>
    </section>
  <% else %>
    <section class="grid gap-4 md:grid-cols-4">
      <div class="rounded-2xl border border-gray-800 bg-gray-900/70 p-4">
        <p class="text-[11px] uppercase tracking-[0.18em] text-gray-500">Started</p>
        <p class="mt-2 text-sm text-white"><%= bearclaw_run_timestamp(@run["started_at"]) %></p>
      </div>
      <div class="rounded-2xl border border-gray-800 bg-gray-900/70 p-4">
        <p class="text-[11px] uppercase tracking-[0.18em] text-gray-500">Updated</p>
        <p class="mt-2 text-sm text-white"><%= bearclaw_run_timestamp(@run["updated_at"]) %></p>
      </div>
      <div class="rounded-2xl border border-gray-800 bg-gray-900/70 p-4">
        <p class="text-[11px] uppercase tracking-[0.18em] text-gray-500">User</p>
        <p class="mt-2 text-sm text-white"><%= @run["user_id"] %></p>
      </div>
      <div class="rounded-2xl border border-gray-800 bg-gray-900/70 p-4">
        <p class="text-[11px] uppercase tracking-[0.18em] text-gray-500">Events</p>
        <p class="mt-2 text-sm text-white" data-run-stream-target="count"><%= @events.size %></p>
      </div>
    </section>

    <section class="rounded-3xl border border-gray-800 bg-gray-900/60 p-5">
      <div class="flex items-center justify-between gap-4">
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-300">Timeline</h2>
          <p class="mt-1 text-sm text-gray-500">Artifact payloads are rendered after BearClaw redaction. Raw bearer tokens should never appear here.</p>
        </div>
      </div>

      <ol id="run-events" class="mt-5 space-y-4" data-run-stream-target="events">
        <% @events.each do |event| %>
          <%= render "event", event: event %>
        <% end %>
      </ol>

      <template data-run-stream-target="emptyState">
        <li class="rounded-2xl border border-dashed border-gray-700 bg-gray-950/40 px-4 py-8 text-center text-sm text-gray-500">
          Waiting for BearClaw to emit run events.
        </li>
      </template>
    </section>
  <% end %>
</div>
