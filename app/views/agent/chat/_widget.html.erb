<% floating = local_assigns.fetch(:floating, false) %>
<% expanded = local_assigns.fetch(:expanded, !floating) %>
<% launcher_classes = [
  "group flex items-center gap-3 rounded-full border border-white/10 bg-gray-950/90 px-4 py-3",
  "text-left shadow-[0_20px_60px_rgba(0,0,0,0.45)] backdrop-blur-xl transition hover:border-white/20 hover:bg-gray-900/95",
  "focus:outline-none focus:ring-2 focus:ring-emerald-400/60 focus:ring-offset-2 focus:ring-offset-gray-950"
].join(" ") %>
<% panel_classes = if floating
  "flex h-[min(34rem,calc(100vh-2rem))] max-h-[34rem] w-[min(calc(100vw-2rem),24rem)] flex-col overflow-hidden rounded-[1.5rem] border border-white/10 bg-gray-950/95 shadow-[0_28px_90px_rgba(0,0,0,0.55)] backdrop-blur-xl"
else
  "flex min-h-[36rem] w-full flex-1 flex-col overflow-hidden rounded-[1.75rem] border border-white/10 bg-gray-950/95 shadow-[0_24px_80px_rgba(0,0,0,0.45)]"
end %>
<% panel_state_classes = if floating
  expanded ? "transition-all duration-200 ease-out" : "hidden pointer-events-none opacity-0 translate-y-3 scale-[0.98] transition-all duration-200 ease-out"
else
  ""
end %>

<div
  class="<%= floating ? "fixed bottom-4 left-4 z-50" : "flex w-full flex-1 flex-col" %>"
  data-controller="chat"
  data-action="keydown@window->chat#handleWindowKeydown"
  data-chat-expanded-value="<%= expanded %>"
>
  <% if floating %>
    <button
      type="button"
      class="<%= launcher_classes %>"
      data-action="click->chat#toggle"
      data-chat-target="launcher"
      aria-controls="bearclaw-chat-panel"
      aria-expanded="<%= expanded %>"
      aria-label="Open BearClaw chat"
    >
      <span class="flex h-11 w-11 items-center justify-center rounded-full border border-emerald-400/20 bg-emerald-400/10 text-[0.65rem] font-semibold tracking-[0.28em] text-emerald-200">BC</span>
      <span class="flex min-w-0 flex-col">
        <span class="text-sm font-semibold text-white">BearClaw</span>
        <span class="text-xs text-gray-400">Open BearClaw chat</span>
      </span>
      <span class="h-2.5 w-2.5 rounded-full bg-emerald-400 shadow-[0_0_16px_rgba(74,222,128,0.9)]"></span>
    </button>
  <% end %>

  <section
    id="bearclaw-chat-panel"
    class="<%= [panel_classes, panel_state_classes].reject(&:blank?).join(" ") %>"
    data-chat-target="panel"
  >
    <header class="flex items-center justify-between gap-3 border-b border-white/10 px-4 py-3">
      <div class="flex min-w-0 items-center gap-3">
        <span class="flex h-10 w-10 items-center justify-center rounded-2xl border border-emerald-400/20 bg-emerald-400/10 text-[0.65rem] font-semibold tracking-[0.28em] text-emerald-200">BC</span>
        <div class="min-w-0">
          <p class="truncate text-sm font-semibold text-white">BearClaw</p>
          <p class="truncate text-xs text-gray-500">Operator chat for the AI agent</p>
        </div>
      </div>

      <div class="flex items-center gap-2">
        <button
          type="button"
          data-action="click->chat#clear"
          class="rounded-full border border-white/10 px-3 py-1.5 text-xs text-gray-400 transition hover:border-white/20 hover:text-gray-200"
        >
          Clear
        </button>
        <% if floating %>
          <button
            type="button"
            data-action="click->chat#close"
            class="flex h-8 w-8 items-center justify-center rounded-full border border-white/10 text-gray-400 transition hover:border-white/20 hover:text-gray-200"
            aria-label="Close BearClaw chat"
          >
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path stroke-linecap="round" d="M5 5l10 10M15 5 5 15" />
            </svg>
          </button>
        <% end %>
      </div>
    </header>

    <div
      id="chat-messages"
      class="flex-1 min-h-0 space-y-3 overflow-y-auto px-4 py-4"
      data-chat-target="messages"
    >
      <div
        id="chat-empty"
        class="flex h-full flex-col items-center justify-center gap-4 text-center"
        data-chat-target="empty"
      >
        <span class="flex h-14 w-14 items-center justify-center rounded-[1.25rem] border border-emerald-400/20 bg-emerald-400/10 text-xs font-semibold tracking-[0.3em] text-emerald-200">BC</span>
        <div class="space-y-1">
          <p class="text-sm font-medium text-gray-200">Start a conversation</p>
          <p class="max-w-xs text-xs leading-5 text-gray-500">Ask BearClaw to inspect services, explain alerts, or plan homelab work.</p>
        </div>
      </div>
    </div>

    <div
      class="hidden items-center gap-2 px-4 pb-3 text-xs text-gray-500"
      data-chat-target="loading"
    >
      <div class="flex items-center gap-1">
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-300 animate-bounce" style="animation-delay: 0ms"></span>
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-300 animate-bounce" style="animation-delay: 120ms"></span>
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-300 animate-bounce" style="animation-delay: 240ms"></span>
      </div>
      BearClaw is thinking
    </div>

    <div class="border-t border-white/10 p-4">
      <%= form_with url: agent_chat_index_path,
            data: {
              action: "submit->chat#onSubmit turbo:submit-end->chat#onSubmitEnd",
              chat_target: "form"
            } do |f| %>
        <div class="flex items-end gap-3 rounded-[1.25rem] border border-white/10 bg-black/20 px-3 py-3 transition focus-within:border-emerald-400/30">
          <%= f.text_area :message,
                placeholder: "Message BearClaw",
                rows: 1,
                autocomplete: "off",
                class: "min-h-[1.5rem] flex-1 resize-none bg-transparent text-sm leading-6 text-white outline-none placeholder:text-gray-600",
                data: {
                  chat_target: "input",
                  action: "keydown->chat#handleKeydown input->chat#autoResize"
                } %>
          <button
            type="submit"
            data-chat-target="submit"
            class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-emerald-400 text-gray-950 transition hover:bg-emerald-300 disabled:cursor-not-allowed disabled:opacity-40"
            aria-label="Send message"
          >
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4 10 11-5-3.5 10-1.9-3.3L4 10Z" />
            </svg>
          </button>
        </div>
        <p class="mt-2 px-1 text-[11px] text-gray-600">Enter to send. Shift+Enter adds a new line.</p>
      <% end %>
    </div>
  </section>
</div>
