<% content_for :title, "Engine — Finances — BearClaw" %>

<div class="max-w-3xl mx-auto space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-white mb-1">Trading Engine</h1>
    <p class="text-gray-500 text-sm">Start, stop, and inspect the Kodiak trading engine.</p>
  </div>

  <% if flash[:notice] %>
    <div class="bg-green-900/40 border border-green-800 text-green-300 rounded-xl p-4 text-sm"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert] %>
    <div class="bg-red-900/40 border border-red-800 text-red-300 rounded-xl p-4 text-sm"><%= flash[:alert] %></div>
  <% end %>

  <% if @error %>
    <div class="bg-red-900/40 border border-red-800 text-red-300 rounded-xl p-4 text-sm"><%= @error %></div>
  <% else %>

    <% running = @engine_status&.dig("running") || @engine_status&.dig("status") == "running" %>

    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 space-y-5">
      <div class="flex items-center gap-3">
        <span class="inline-block w-3 h-3 rounded-full <%= running ? 'bg-green-400' : 'bg-gray-600' %>"></span>
        <span class="text-xl font-semibold text-white"><%= running ? "Running" : "Stopped" %></span>
      </div>

      <% if @engine_status %>
        <dl class="grid grid-cols-2 gap-x-8 gap-y-3 text-sm">
          <% @engine_status.except("running", "status").each do |key, val| %>
            <dt class="text-gray-500 capitalize"><%= key.to_s.humanize %></dt>
            <dd class="text-gray-200 font-mono"><%= val %></dd>
          <% end %>
        </dl>
      <% end %>

      <div class="flex gap-3 pt-2 border-t border-gray-800">
        <% if running %>
          <%= button_to "Stop Engine",
                finances_engine_stop_path,
                method: :post,
                data: { turbo_confirm: "Stop the trading engine?" },
                class: "px-4 py-2 rounded-lg bg-red-700 hover:bg-red-600 text-white text-sm font-medium" %>
        <% else %>
          <%= button_to "Start Engine (dry run)",
                finances_engine_start_path(dry_run: 1),
                method: :post,
                class: "px-4 py-2 rounded-lg bg-yellow-700 hover:bg-yellow-600 text-white text-sm font-medium" %>
          <%= button_to "Start Engine (live)",
                finances_engine_start_path,
                method: :post,
                data: { turbo_confirm: "Start the trading engine in live paper mode?" },
                class: "px-4 py-2 rounded-lg bg-green-700 hover:bg-green-600 text-white text-sm font-medium" %>
        <% end %>
      </div>
    </div>

  <% end %>
</div>
