<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "BearClaw" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="turbo-prefetch" content="false">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= tag.link rel: "stylesheet", href: "#{asset_path('tailwind.css')}?v=20260320a", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-950 text-gray-100 min-h-screen flex flex-col">

    <% if current_user %>
      <nav class="bg-gray-900 border-b border-gray-800 px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-8">
          <span class="text-white font-bold tracking-wide text-lg">BearClaw</span>

          <div class="flex items-center gap-4 text-sm">
            <%= link_to "Agent", agent_root_path,
                  class: "px-3 py-1.5 rounded hover:bg-gray-800 transition #{controller.class.name.start_with?('Agent::') ? 'bg-gray-800 text-white' : 'text-gray-400'}" %>

            <% if current_user.can_access?(:home) %>
              <%= link_to "Home", home_root_path,
                    class: "px-3 py-1.5 rounded hover:bg-gray-800 transition #{controller.class.name.start_with?('Home::') ? 'bg-gray-800 text-white' : 'text-gray-400'}" %>
            <% end %>

            <% if current_user.can_access?(:security) %>
              <%= link_to "Security", security_root_path,
                    class: "px-3 py-1.5 rounded hover:bg-gray-800 transition #{controller.class.name.start_with?('Security::') ? 'bg-gray-800 text-white' : 'text-gray-400'}" %>
            <% end %>

            <% if current_user.admin? %>
              <%= link_to "Admin", admin_root_path,
                    class: "px-3 py-1.5 rounded hover:bg-gray-800 transition #{controller.class.name.start_with?('Admin::') ? 'bg-gray-800 text-white' : 'text-gray-400'}" %>
            <% end %>
          </div>
        </div>

        <div class="flex items-center gap-3">
          <% if current_user.can_access?(:home) %>
            <%= link_to settings_root_path,
                  title: "Settings",
                  class: "text-gray-500 hover:text-gray-300 transition #{controller.class.name.start_with?('Settings::') ? 'text-white' : ''}" do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
              </svg>
            <% end %>
          <% end %>

          <% if current_user.avatar_url.present? %>
            <img src="<%= current_user.avatar_url %>" class="w-7 h-7 rounded-full" alt="<%= current_user.name %>">
          <% end %>
          <span class="text-gray-400 text-sm"><%= current_user.name %></span>
          <span class="text-xs px-2 py-0.5 rounded-full font-medium
            <%= case current_user.role
                when 'admin'    then 'bg-red-900 text-red-300'
                when 'operator' then 'bg-blue-900 text-blue-300'
                when 'reviewer' then 'bg-yellow-900 text-yellow-300'
                else                 'bg-gray-800 text-gray-400'
                end %>">
            <%= current_user.role %>
          </span>
          <%= button_to "Sign out", logout_path, method: :post,
                class: "text-xs text-gray-500 hover:text-gray-300 transition ml-2" %>
        </div>
      </nav>
    <% end %>

    <% if notice.present? %>
      <div class="bg-green-900/50 border-b border-green-700 text-green-300 text-sm px-6 py-2"><%= notice %></div>
    <% end %>
    <% if alert.present? %>
      <div class="bg-red-900/50 border-b border-red-700 text-red-300 text-sm px-6 py-2"><%= alert %></div>
    <% end %>

    <main class="flex-1 p-4">
      <%= yield %>
    </main>

    <% if bearclaw_chat_widget_enabled? && !bearclaw_chat_widget_embedded? %>
      <%= render "agent/chat/widget", floating: true, expanded: false %>
    <% end %>

  </body>
</html>
