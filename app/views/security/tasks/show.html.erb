<% content_for :title, "Task #{@task["id"]} — Security — BearClaw" %>
<% parsed_args = @task["parsed_args"] || ursa_parse_json(@task["args"]) %>

<div class="max-w-4xl mx-auto space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-white mb-1 font-mono"><%= @task["id"] %></h1>
    <p class="text-gray-500 text-sm">Task detail and captured output.</p>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 space-y-4">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-gray-500 text-sm">Session</p>
        <p class="text-white font-mono"><%= @task["session_id"] %></p>
      </div>
      <span class="text-xs px-3 py-1 rounded-full <%= ursa_status_classes(@task["status"]) %>"><%= @task["status"] %></span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
      <div>
        <p class="text-gray-500 mb-1">Task Type</p>
        <p class="text-white"><%= @task["task_type"] %></p>
      </div>
      <div>
        <p class="text-gray-500 mb-1">Created</p>
        <p class="text-white"><%= ursa_timestamp(@task["created_at"]) %></p>
      </div>
      <div class="md:col-span-2">
        <p class="text-gray-500 mb-1">Args</p>
        <pre class="bg-gray-950 border border-gray-800 rounded-lg p-4 text-gray-200 text-xs overflow-x-auto"><%= JSON.pretty_generate(parsed_args) %></pre>
      </div>
      <div class="md:col-span-2">
        <p class="text-gray-500 mb-1">Output</p>
        <pre class="bg-gray-950 border border-gray-800 rounded-lg p-4 text-gray-200 text-xs overflow-x-auto whitespace-pre-wrap"><%= @task["result"].presence || @task["error"].presence || "No output yet." %></pre>
      </div>
    </div>
  </div>
</div>
