<% content_for :title, "Sessions — Security — BearClaw" %>

<div class="max-w-6xl mx-auto space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-white mb-1">Sessions</h1>
    <p class="text-gray-500 text-sm">Active, stale, and dead implant sessions.</p>
  </div>

  <%= form_with url: security_sessions_path, method: :get, class: "grid grid-cols-1 md:grid-cols-4 gap-3 bg-gray-900 border border-gray-800 rounded-xl p-4" do %>
    <%= select_tag :status, options_for_select([["All statuses", ""], ["Active", "active"], ["Stale", "stale"], ["Dead", "dead"]], @filters["status"]), class: "bg-gray-950 border border-gray-800 rounded-lg px-3 py-2 text-sm text-white" %>
    <%= text_field_tag :campaign, @filters["campaign"], placeholder: "Campaign", class: "bg-gray-950 border border-gray-800 rounded-lg px-3 py-2 text-sm text-white" %>
    <%= text_field_tag :tag, @filters["tag"], placeholder: "Tag", class: "bg-gray-950 border border-gray-800 rounded-lg px-3 py-2 text-sm text-white" %>
    <div class="flex gap-2">
      <%= submit_tag "Filter", class: "px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-500 text-white text-sm cursor-pointer" %>
      <%= link_to "Reset", security_sessions_path, class: "px-4 py-2 rounded-lg border border-gray-700 text-gray-300 text-sm" %>
    </div>
  <% end %>

  <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-950/60 border-b border-gray-800 text-gray-500">
        <tr>
          <th class="px-4 py-3 text-left font-medium">ID</th>
          <th class="px-4 py-3 text-left font-medium">User@Host</th>
          <th class="px-4 py-3 text-left font-medium">Campaign</th>
          <th class="px-4 py-3 text-left font-medium">Tags</th>
          <th class="px-4 py-3 text-left font-medium">Last Seen</th>
          <th class="px-4 py-3 text-left font-medium">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-800">
        <% @sessions.each do |session| %>
          <tr class="hover:bg-gray-800/40">
            <td class="px-4 py-3"><%= link_to session["id"], security_session_path(session["id"]), class: "font-mono text-sky-300" %></td>
            <td class="px-4 py-3 text-white font-mono"><%= "#{session["username"]}@#{session["hostname"]}" %></td>
            <td class="px-4 py-3 text-gray-300 font-mono"><%= session["campaign"].presence || "-" %></td>
            <td class="px-4 py-3 text-gray-400 font-mono"><%= session["tags"].presence || "-" %></td>
            <td class="px-4 py-3 text-gray-400"><%= ursa_time_ago(session["last_seen"]) %></td>
            <td class="px-4 py-3"><span class="text-xs px-2 py-1 rounded-full <%= ursa_status_classes(session["status"]) %>"><%= session["status"] %></span></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
