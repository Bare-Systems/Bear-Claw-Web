<% content_for :title, "Network — Security — BearClaw" %>

<div class="max-w-6xl mx-auto space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-white mb-1">Network Devices</h1>
      <p class="text-gray-500 text-sm">Home-network inventory from Ursa. Unknown (unbaselined) devices are highlighted.</p>
    </div>
    <%= button_to "Set Baseline", security_network_baseline_path, method: :post,
          class: "px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-500 text-white text-sm cursor-pointer whitespace-nowrap",
          form: { data: { turbo_confirm: "Mark every currently-seen device as trusted? This becomes the new baseline." } } %>
  </div>

  <div class="grid grid-cols-3 gap-4">
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
      <div class="text-3xl font-semibold text-sky-300"><%= @counts["total"].to_i %></div>
      <p class="text-gray-500 text-sm mt-2">Total devices</p>
    </div>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
      <div class="text-3xl font-semibold text-emerald-300"><%= @counts["trusted"].to_i %></div>
      <p class="text-gray-500 text-sm mt-2">Trusted</p>
    </div>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
      <div class="text-3xl font-semibold <%= @counts["untrusted"].to_i.positive? ? "text-amber-300" : "text-gray-400" %>"><%= @counts["untrusted"].to_i %></div>
      <p class="text-gray-500 text-sm mt-2">Unknown</p>
    </div>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-950/60 border-b border-gray-800 text-gray-500">
        <tr>
          <th class="px-4 py-3 text-left font-medium">IP</th>
          <th class="px-4 py-3 text-left font-medium">MAC</th>
          <th class="px-4 py-3 text-left font-medium">Vendor</th>
          <th class="px-4 py-3 text-left font-medium">Label</th>
          <th class="px-4 py-3 text-left font-medium">Trust</th>
          <th class="px-4 py-3 text-left font-medium">Last Seen</th>
          <th class="px-4 py-3 text-right font-medium">Seen</th>
          <th class="px-4 py-3 text-right font-medium">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-800">
        <% if @devices.empty? %>
          <tr><td colspan="8" class="px-4 py-8 text-center text-gray-500">No devices recorded yet. Run a network scan to populate the inventory.</td></tr>
        <% end %>
        <%= render partial: "device_row", collection: @devices, as: :device %>
      </tbody>
    </table>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-800 flex items-center justify-between gap-3">
      <div>
        <h2 class="text-lg font-semibold text-white">DNS Talkers</h2>
        <p class="text-gray-500 text-xs mt-0.5">Which devices are making the most DNS queries (Pi-hole, last 24h).</p>
      </div>
      <% if @dns["available"] %>
        <span class="text-xs text-gray-400">
          <%= @dns["total"].to_i %> queries · <%= @dns["blocked"].to_i %> blocked
          (<%= (@dns["block_ratio"].to_f * 100).round(1) %>%)
        </span>
      <% end %>
    </div>

    <% if !@dns["available"] %>
      <div class="px-5 py-8 text-center text-gray-500 text-sm">
        DNS insight unavailable — Pi-hole's query database could not be read.
      </div>
    <% elsif @dns_talkers.empty? %>
      <div class="px-5 py-8 text-center text-gray-500 text-sm">No DNS queries in the last 24 hours.</div>
    <% else %>
      <table class="w-full text-sm">
        <thead class="bg-gray-950/60 border-b border-gray-800 text-gray-500">
          <tr>
            <th class="px-4 py-3 text-left font-medium">Client</th>
            <th class="px-4 py-3 text-right font-medium">Queries</th>
            <th class="px-4 py-3 text-right font-medium">Blocked</th>
            <th class="px-4 py-3 text-right font-medium">Block %</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <% @dns_talkers.each do |talker| %>
            <tr class="hover:bg-gray-800/40">
              <td class="px-4 py-3 text-white font-mono"><%= talker["client"] %></td>
              <td class="px-4 py-3 text-gray-300 text-right"><%= talker["total"].to_i %></td>
              <td class="px-4 py-3 text-gray-400 text-right"><%= talker["blocked"].to_i %></td>
              <td class="px-4 py-3 text-right">
                <% ratio = (talker["block_ratio"].to_f * 100).round(1) %>
                <span class="text-xs px-2 py-1 rounded-full <%= ratio >= 25 ? ursa_status_classes("warning") : ursa_status_classes("active") %>">
                  <%= ratio %>%
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>
