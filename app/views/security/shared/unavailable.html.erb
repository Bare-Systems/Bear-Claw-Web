<% content_for :title, "Security Unavailable — BearClaw" %>

<div class="max-w-3xl mx-auto">
  <div class="bg-gray-900 border border-red-900/60 rounded-xl p-6">
    <p class="text-xs uppercase tracking-[0.2em] text-red-400 mb-3">Security</p>
    <h1 class="text-2xl font-bold text-white mb-3">Ursa is currently unavailable</h1>
    <p class="text-gray-300 mb-6">
      <%= @security_error_message.presence || "BearClaw could not complete the request to Ursa." %>
    </p>

    <div class="flex items-center gap-3 text-sm">
      <%= link_to "Retry", request.fullpath, class: "px-4 py-2 rounded-lg bg-red-700 hover:bg-red-600 text-white" %>
      <%= link_to "Security Home", security_root_path, class: "px-4 py-2 rounded-lg border border-gray-700 text-gray-200 hover:border-gray-600" %>
    </div>
  </div>
</div>
