<section
  id="dashboard-priority-watch"
  data-controller="dashboard-section"
  data-dashboard-section-storage-key-value="home-dashboard-priority-watch"
  class="rounded-2xl border border-red-900/40 bg-[linear-gradient(180deg,rgba(127,29,29,0.18),rgba(17,24,39,0.96))] px-3 py-3 shadow-[0_16px_48px_rgba(127,29,29,0.16)]"
>
  <details
    open
    data-dashboard-section-target="details"
    data-action="toggle->dashboard-section#toggle"
    class="group"
  >
    <summary class="flex cursor-pointer list-none items-start justify-between gap-3 [&::-webkit-details-marker]:hidden">
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-2">
          <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-red-200/80">Priority Watch</p>
          <span class="rounded-full border border-amber-500/25 bg-amber-950/35 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.18em] text-amber-100/85"><%= pluralize(alerts.size, "item") %></span>
        </div>
        <h2 class="mt-1 text-sm font-semibold text-white">Pinned incidents and stale signals</h2>
      </div>
      <span class="inline-flex shrink-0 items-center gap-2 rounded-full border border-red-700/45 bg-red-950/35 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-red-100 transition group-hover:bg-red-950/60">
        <span data-dashboard-section-target="buttonLabel">Collapse</span>
      </span>
    </summary>

    <p class="mt-2 text-[11px] text-red-100/70">Only widgets needing attention are promoted here.</p>

    <div class="mt-3 space-y-2">
      <% alerts.each do |alert| %>
        <a
          href="#tile-<%= alert[:tile].id %>"
          class="block rounded-xl border border-white/10 bg-gray-950/78 px-3 py-3 transition hover:border-white/20 hover:bg-gray-950/90"
        >
          <div class="flex items-start justify-between gap-2">
            <div class="min-w-0">
              <p class="text-sm font-semibold text-white"><%= alert[:tile].display_title %></p>
              <p class="mt-0.5 text-[11px] text-gray-400"><%= alert[:widget].display_title %> · <%= alert[:section_name] %></p>
            </div>
            <span
              data-alert-label
              class="shrink-0 rounded-full border px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.18em] <%= dashboard_alert_badge_classes(alert[:alert_state]) %>"
            ><%= alert[:label] %></span>
          </div>
          <div class="mt-2 flex items-center justify-between gap-3">
            <p class="text-xs text-gray-200"><%= alert[:detail] %></p>
            <p class="shrink-0 text-[10px] font-medium uppercase tracking-[0.22em] text-red-100/65">Open</p>
          </div>
        </a>
      <% end %>
    </div>
  </details>
</section>
