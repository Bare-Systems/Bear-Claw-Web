<section id="dashboard-priority-watch" class="mb-5 rounded-2xl border border-red-900/40 bg-[linear-gradient(135deg,rgba(127,29,29,0.26),rgba(17,24,39,0.92))] px-4 py-4 shadow-[0_16px_48px_rgba(127,29,29,0.18)] sm:px-5">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-red-200/80">Priority Watch</p>
      <h2 class="mt-1 text-lg font-semibold text-white">Pinned incidents and stale signals</h2>
    </div>
    <p class="text-xs text-red-100/70">Only widgets needing attention are promoted here.</p>
  </div>

  <div class="mt-4 grid gap-3 lg:grid-cols-2 xl:grid-cols-3">
    <% alerts.each do |alert| %>
      <a
        href="#tile-<%= alert[:tile].id %>"
        class="block rounded-2xl border border-white/10 bg-gray-950/75 px-4 py-4 transition hover:border-white/20 hover:bg-gray-950/90"
      >
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <p class="text-sm font-semibold text-white"><%= alert[:tile].display_title %></p>
            <p class="mt-1 text-xs text-gray-400"><%= alert[:widget].display_title %> · <%= alert[:section_name] %></p>
          </div>
          <span
            data-alert-label
            class="shrink-0 rounded-full border px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.2em] <%= dashboard_alert_badge_classes(alert[:alert_state]) %>"
          ><%= alert[:label] %></span>
        </div>
        <p class="mt-3 text-sm text-gray-200"><%= alert[:detail] %></p>
        <p class="mt-3 text-[11px] font-medium uppercase tracking-[0.22em] text-red-100/65">Open tile</p>
      </a>
    <% end %>
  </div>
</section>
