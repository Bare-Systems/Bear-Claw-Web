<% cap       = widget.device_capability %>
<% presenter = Home::MetricPresenter.new(cap) %>
<% chrome_free_tile = local_assigns[:tile].present? && dashboard_tile_chrome_free_air_quality?(local_assigns[:tile]) %>
<% container_classes = if chrome_free_tile
  "flex h-full w-full flex-col rounded-xl bg-gray-900/70 p-3 sm:p-4"
else
  "rounded-xl border border-gray-800 bg-gray-900/70 p-3 sm:p-4"
end %>

<section id="widget-<%= widget.id %>" class="<%= container_classes %>">

  <%# ── Header: icon · name · scope · quality badge ──────────────────────── %>
  <div class="flex items-start justify-between gap-2">
    <div class="flex items-center gap-2.5 min-w-0">
      <span class="flex-shrink-0 text-xl leading-none" aria-hidden="true"><%= presenter.icon %></span>
      <div class="min-w-0">
        <h4 class="text-sm font-semibold text-white truncate"><%= presenter.label %></h4>
        <% if presenter.scope_label %>
          <p class="text-xs text-gray-500"><%= presenter.scope_label %></p>
        <% end %>
      </div>
    </div>
    <span class="flex-shrink-0 rounded-full border px-2 py-0.5 text-[11px] font-medium sm:text-xs <%= presenter.quality_badge_class %>">
      <%= presenter.threshold_label %>
    </span>
  </div>

  <%# ── Primary reading ───────────────────────────────────────────────────── %>
  <div class="mt-5">
    <p class="text-3xl font-bold leading-none tracking-tight sm:text-4xl <%= presenter.value_color_class %>">
      <%= presenter.display_value %>
    </p>
    <p class="mt-1.5 text-sm text-gray-500">
      <%= presenter.unit.presence || "No reading yet" %>
    </p>
  </div>

  <%# ── Gauge bar (shown when a numeric scale exists for this metric) ──────── %>
  <% if (pct = presenter.gauge_pct) %>
    <div class="mt-4 h-1 overflow-hidden rounded-full bg-gray-800">
      <div class="h-full rounded-full transition-all duration-700 <%= presenter.gauge_fill_class %>"
           style="width: <%= pct %>%">
      </div>
    </div>
  <% end %>

  <%# ── Footer: device name · timestamp ───────────────────────────────────── %>
  <div class="mt-3 flex items-center justify-between gap-3">
    <p class="min-w-0 truncate text-xs text-gray-600"><%= widget.device&.name || "Unassigned device" %></p>
    <%= render "home/widgets/health_meta", widget: widget %>
  </div>

</section>
