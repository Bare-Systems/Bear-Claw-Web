<article
  id="tile-<%= tile.id %>"
  class="flex flex-col overflow-hidden rounded-2xl border border-gray-800 bg-gray-950/90 shadow-[0_18px_60px_rgba(15,23,42,0.32)] transition-[grid-column,grid-row,border-color,box-shadow,background-color,opacity]"
  style="<%= dashboard_tile_style(tile) %>"
  data-dashboard-layout-target="item"
  data-tile-id="<%= tile.id %>"
  data-position="<%= tile.position %>"
  data-row="<%= tile.row %>"
  data-column="<%= tile.column %>"
  data-width="<%= tile.width %>"
  data-height="<%= tile.height %>"
  data-update-url="<%= home_dashboard_tile_path(tile, format: :json) %>"
>
  <div
    class="flex items-start justify-between gap-3 border-b border-gray-800 px-4 py-4 <%= edit_mode ? 'cursor-grab select-none active:cursor-grabbing' : '' %>"
    <% if edit_mode %>
      data-action="pointerdown->dashboard-layout#startMove"
      style="touch-action: none;"
    <% end %>
  >
    <div>
      <h3 class="text-sm font-semibold text-white"><%= tile.display_title %></h3>
      <% if edit_mode %>
        <p class="mt-1 text-xs text-gray-500" data-dashboard-layout-target="meta">
          Row <span data-dashboard-layout-field="row"><%= tile.row %></span> · Column <span data-dashboard-layout-field="column"><%= tile.column %></span> · Size <span data-dashboard-layout-field="size"><%= "#{tile.width}×#{tile.height}" %></span> · <%= pluralize(tile.dashboard_widgets.size, "widget") %>
        </p>
      <% end %>
    </div>
    <% if edit_mode %>
      <div class="flex items-center gap-2">
        <span class="rounded-full border border-sky-800/70 bg-sky-950/60 px-3 py-1 text-[11px] font-medium uppercase tracking-wide text-sky-200">drag header</span>
        <span class="rounded-full border border-sky-800/70 bg-sky-950/60 px-2 py-1 text-[11px] font-medium uppercase tracking-wide text-sky-200">editable</span>
      </div>
    <% end %>
  </div>

  <div class="flex-1 space-y-3 p-4">
    <% if tile.dashboard_widgets.any? %>
      <% tile.dashboard_widgets.each do |widget| %>
        <%= render dashboard_widget_partial(widget), widget: widget %>
      <% end %>
    <% else %>
      <div class="flex h-full min-h-44 items-center justify-center rounded-xl border border-dashed border-gray-700 bg-gray-900/70 px-4 text-center">
        <div>
          <p class="text-sm font-medium text-gray-300">Empty Tile</p>
          <p class="mt-1 text-sm text-gray-500">Add a widget in edit mode to turn this into a live dashboard block.</p>
        </div>
      </div>
    <% end %>
  </div>

  <% if edit_mode %>
    <div class="flex items-center justify-end border-t border-gray-800 px-4 py-2">
      <button
        type="button"
        class="rounded-lg border border-gray-700 px-2 py-1 text-[11px] uppercase tracking-[0.24em] text-gray-300 transition hover:bg-gray-800"
        data-action="pointerdown->dashboard-layout#startResize"
        style="touch-action: none;"
      >
        resize corner
      </button>
    </div>
  <% end %>
</article>
