<% content_for :title, "Home — BearClaw" %>

<div class="w-full" data-controller="dashboard-sync">

  <%# ── Top bar: label · sync status · actions ─────────────────────────────── %>
  <div class="mb-4 flex items-center justify-between">
    <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-400">Home Ops</p>
    <div class="flex items-center gap-3">
      <span id="dashboard-sync-status" data-dashboard-sync-target="status">
        <span class="text-xs text-gray-600">Connecting…</span>
      </span>
      <%= link_to(@edit_mode ? "Done Editing" : "Edit",
            home_root_path(edit: @edit_mode ? nil : 1, dashboard: params[:dashboard]),
            class: "rounded-lg border border-sky-700/70 bg-sky-900/30 px-3 py-1.5 text-sm font-medium text-sky-200 transition hover:bg-sky-900/50") %>
      <%= link_to "Cameras", home_cameras_path, class: "rounded-lg border border-gray-700 px-3 py-1.5 text-sm text-gray-300 transition hover:bg-gray-800/40" %>
      <%= link_to "Zones", home_zones_path, class: "rounded-lg border border-gray-700 px-3 py-1.5 text-sm text-gray-300 transition hover:bg-gray-800/40" %>
    </div>
  </div>

  <%# ── Error banners ──────────────────────────────────────────────────────── %>
  <% if @koala_error.present? %>
    <div class="mb-4 rounded-2xl border border-amber-800/70 bg-amber-950/60 px-5 py-4">
      <p class="text-sm font-semibold text-amber-200">Koala sync failed</p>
      <p class="mt-1 text-sm text-amber-100/80"><%= @koala_error %></p>
    </div>
  <% end %>

  <% if @polar_error.present? %>
    <div class="mb-4 rounded-2xl border border-cyan-800/70 bg-cyan-950/60 px-5 py-4">
      <p class="text-sm font-semibold text-cyan-200">Polar sync failed</p>
      <p class="mt-1 text-sm text-cyan-100/80"><%= @polar_error %></p>
    </div>
  <% end %>

  <% if @kodiak_error.present? %>
    <div class="mb-4 rounded-2xl border border-yellow-800/70 bg-yellow-950/60 px-5 py-4">
      <p class="text-sm font-semibold text-yellow-200">Kodiak sync failed</p>
      <p class="mt-1 text-sm text-yellow-100/80"><%= @kodiak_error %></p>
    </div>
  <% end %>

  <% if @ursa_error.present? %>
    <div class="mb-4 rounded-2xl border border-red-800/70 bg-red-950/60 px-5 py-4">
      <p class="text-sm font-semibold text-red-200">Ursa sync failed</p>
      <p class="mt-1 text-sm text-red-100/80"><%= @ursa_error %></p>
    </div>
  <% end %>

  <%# ── Dashboard tabs ─────────────────────────────────────────────────────── %>
  <% if @dashboards.size > 1 %>
    <div class="mb-5 flex items-center gap-1 border-b border-gray-800 pb-px">
      <% @dashboards.each do |dash| %>
        <% active = dash.id == @dashboard.id %>
        <%= link_to dash.name,
              home_root_path(dashboard: dash.name, edit: @edit_mode ? 1 : nil),
              class: "px-4 py-2 text-sm font-medium rounded-t-lg transition border-b-2 -mb-px
                #{active ? 'border-sky-500 text-white bg-gray-900/60' : 'border-transparent text-gray-500 hover:text-gray-300 hover:border-gray-600'}" %>
      <% end %>
    </div>
  <% end %>

  <% if @edit_mode %>
    <p class="mb-3 text-xs uppercase tracking-[0.22em] text-sky-300">Drag a tile header to move · drag the corner handle to resize · dense grid packs tiles to avoid dead space</p>
  <% end %>

  <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_22rem]">
    <section>
      <div class="pb-3">
        <% if @dashboard.dashboard_tiles.empty? %>
          <div class="flex min-h-[12rem] items-center justify-center rounded-2xl border border-dashed border-gray-700 bg-gray-900/30 text-gray-500">
            <div class="text-center">
              <p class="text-sm">No tiles yet.</p>
              <p class="mt-1 text-xs">
                <% if @edit_mode %>
                  Use the editor on the right to add tiles.
                <% else %>
                  <%= link_to "Enter edit mode", home_root_path(edit: 1, dashboard: params[:dashboard]), class: "text-sky-400 hover:underline" %> to add tiles.
                <% end %>
              </p>
            </div>
          </div>
        <% else %>
          <div
            class="grid w-full auto-rows-[minmax(10rem,_1fr)] gap-3"
            style="grid-template-columns: repeat(<%= @dashboard.columns %>, minmax(0, 1fr));"
            <% if @edit_mode %>
              data-controller="dashboard-layout"
              data-dashboard-layout-columns-value="<%= @dashboard.columns %>"
              data-dashboard-layout-max-height-value="<%= DashboardTile::MAX_HEIGHT %>"
              data-dashboard-layout-editing-class="ring-2 ring-sky-400/80"
              data-dashboard-layout-dragging-class="opacity-80"
            <% end %>
          >
            <% @dashboard.dashboard_tiles.each do |tile| %>
              <%= render "home/dashboard_tile", tile: tile, edit_mode: @edit_mode %>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>

    <% if @edit_mode %>
      <aside>
        <%= render "home/dashboard_editor",
          dashboard: @dashboard,
          service_providers: @service_providers,
          service_connections: @service_connections,
          devices: @devices,
          available_capabilities: @available_capabilities %>
      </aside>
    <% end %>
  </div>
</div>
