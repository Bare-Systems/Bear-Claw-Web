<% content_for :title, "Home — BearClaw" %>

<div class="max-w-5xl mx-auto">
  <h1 class="text-2xl font-bold text-white mb-1">Home</h1>
  <p class="text-gray-500 text-sm mb-8">Koala home monitoring</p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <%= link_to home_cameras_path, class: "bg-gray-900 border border-gray-800 rounded-lg p-5 hover:border-gray-600 transition" do %>
      <h2 class="text-white font-semibold mb-1">Cameras</h2>
      <p class="text-gray-500 text-sm">Live camera feeds and discovery</p>
    <% end %>
    <%= link_to home_zones_path, class: "bg-gray-900 border border-gray-800 rounded-lg p-5 hover:border-gray-600 transition" do %>
      <h2 class="text-white font-semibold mb-1">Zones</h2>
      <p class="text-gray-500 text-sm">Detection zone states</p>
    <% end %>
    <%= link_to home_packages_path, class: "bg-gray-900 border border-gray-800 rounded-lg p-5 hover:border-gray-600 transition" do %>
      <h2 class="text-white font-semibold mb-1">Package Detection</h2>
      <p class="text-gray-500 text-sm">Mail and package inference at door</p>
    <% end %>
    <% if current_user.admin? %>
      <%= link_to home_firmware_index_path, class: "bg-gray-900 border border-gray-800 rounded-lg p-5 hover:border-gray-600 transition" do %>
        <h2 class="text-white font-semibold mb-1">Firmware</h2>
        <p class="text-gray-500 text-sm">Device update rollouts</p>
      <% end %>
    <% end %>
  </div>
</div>
