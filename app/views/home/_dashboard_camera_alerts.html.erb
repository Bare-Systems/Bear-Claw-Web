<section
  id="dashboard-camera-alerts"
  data-controller="dashboard-section"
  data-dashboard-section-storage-key-value="home-dashboard-camera-alerts"
  class="rounded-2xl border border-sky-900/40 bg-[linear-gradient(180deg,rgba(12,74,110,0.2),rgba(17,24,39,0.96))] px-3 py-3 shadow-[0_16px_48px_rgba(12,74,110,0.16)]"
>
  <details
    open
    data-dashboard-section-target="details"
    data-action="toggle->dashboard-section#toggle"
    class="group"
  >
    <summary class="flex cursor-pointer list-none items-start justify-between gap-3 [&::-webkit-details-marker]:hidden">
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-2">
          <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-sky-200/80">Recent Alerts</p>
          <span class="rounded-full border border-sky-500/25 bg-sky-950/45 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.18em] text-sky-100/80"><%= pluralize(alerts.size, "alert") %></span>
        </div>
        <h2 class="mt-1 text-sm font-semibold text-white">People and packages detected</h2>
      </div>
      <span class="inline-flex shrink-0 items-center gap-2 rounded-full border border-sky-700/45 bg-sky-950/35 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-sky-100 transition group-hover:bg-sky-950/60">
        <span data-dashboard-section-target="buttonLabel">Collapse</span>
      </span>
    </summary>

    <p class="mt-2 text-[11px] text-sky-100/70">A quiet feed is healthy — only real detections show here.</p>

    <div class="mt-3 space-y-2">
      <% alerts.each do |alert| %>
        <div class="block rounded-xl border border-white/10 bg-gray-950/78 px-3 py-3">
          <div class="flex items-start justify-between gap-2">
            <div class="min-w-0">
              <p class="text-sm font-semibold text-white"><%= koala_alert_headline(alert) %></p>
              <p class="mt-0.5 text-[11px] text-gray-400"><%= koala_alert_meta(alert) %></p>
            </div>
            <span class="shrink-0 rounded-full border px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.18em] <%= koala_alert_badge_classes(alert) %>"><%= alert["label"].to_s.humanize.presence || "Motion" %></span>
          </div>
          <% if alert["id"].present? %>
            <% snapshot_url = snapshot_home_alert_path(alert["id"]) %>
            <button
              type="button"
              class="mt-2 block w-full overflow-hidden rounded-lg border border-white/10 bg-black/40 text-left transition hover:border-sky-500/35 focus:outline-none focus:ring-2 focus:ring-sky-400/60"
              data-action="dashboard-modal#openImage"
              data-dashboard-modal-image-url-param="<%= snapshot_url %>"
              data-dashboard-modal-image-alt-param="<%= "#{koala_alert_headline(alert)} snapshot" %>"
              data-dashboard-modal-caption-param="<%= "#{koala_alert_headline(alert)} · #{koala_alert_meta(alert)} · #{koala_alert_time(alert)}" %>"
            >
              <figure
                data-controller="alert-snapshot"
                class="overflow-hidden"
              >
                <img
                  src="<%= snapshot_url %>"
                  alt="Detection snapshot"
                  loading="lazy"
                  data-action="error->alert-snapshot#failed"
                  class="block max-h-44 w-full object-cover"
                />
              </figure>
            </button>
          <% end %>
          <p class="mt-2 text-[10px] font-medium uppercase tracking-[0.22em] text-sky-100/65"><%= koala_alert_time(alert) %></p>
        </div>
      <% end %>
    </div>
  </details>

  <dialog
    id="dashboard-alert-preview"
    class="w-[min(72rem,calc(100vw-2rem))] max-w-6xl rounded-2xl border border-gray-800 bg-gray-950 p-0 text-gray-100 shadow-[0_28px_90px_rgba(0,0,0,0.55)] backdrop:bg-gray-950/85"
    data-dashboard-modal-target="previewDialog"
    data-action="click->dashboard-modal#backdropClose"
  >
    <div class="flex items-center justify-between gap-3 border-b border-gray-800 px-4 py-3">
      <div class="min-w-0">
        <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-sky-300/80">Alert Preview</p>
        <p class="mt-1 hidden truncate text-sm text-gray-400" data-dashboard-modal-target="previewCaption"></p>
      </div>
      <button
        type="button"
        class="rounded-lg border border-gray-700 px-3 py-1.5 text-xs font-medium text-gray-300 transition hover:bg-gray-800"
        data-action="dashboard-modal#close"
      >
        Close
      </button>
    </div>
    <div class="flex items-center justify-center bg-black/70 p-4">
      <img
        src=""
        alt="Alert snapshot preview"
        class="max-h-[calc(100vh-10rem)] w-full rounded-xl object-contain"
        data-dashboard-modal-target="previewImage"
      />
    </div>
  </dialog>
</section>
