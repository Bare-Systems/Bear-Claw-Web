<% content_for :title, "Edit User — Admin — BearClaw" %>

<div class="max-w-md mx-auto">
  <h1 class="text-2xl font-bold text-white mb-6">Edit User: <%= @user.name %></h1>

  <%= form_with model: [:admin, @user], class: "bg-gray-900 border border-gray-800 rounded-lg p-6 space-y-4" do |f| %>
    <div>
      <label class="block text-gray-400 text-sm mb-1">Email</label>
      <p class="text-white"><%= @user.email %></p>
    </div>
    <div>
      <%= f.label :role, "Role", class: "block text-gray-400 text-sm mb-1" %>
      <%= f.select :role, User.roles.keys.map { |r| [r.capitalize, r] },
            {}, class: "w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-white text-sm" %>
    </div>
    <div class="flex gap-3 pt-2">
      <%= f.submit "Save", class: "bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium px-4 py-2 rounded transition cursor-pointer" %>
      <%= link_to "Cancel", admin_users_path, class: "text-gray-500 hover:text-gray-300 text-sm px-4 py-2 transition" %>
    </div>
  <% end %>
</div>
