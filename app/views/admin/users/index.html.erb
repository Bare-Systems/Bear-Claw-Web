<% content_for :title, "Users — Admin — BearClaw" %>

<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold text-white mb-6">Users</h1>

  <div class="bg-gray-900 border border-gray-800 rounded-lg overflow-hidden">
    <table class="w-full text-sm">
      <thead class="border-b border-gray-800">
        <tr class="text-gray-500 text-left">
          <th class="px-4 py-3 font-medium">Name</th>
          <th class="px-4 py-3 font-medium">Email</th>
          <th class="px-4 py-3 font-medium">Role</th>
          <th class="px-4 py-3 font-medium">Joined</th>
          <th class="px-4 py-3 font-medium"></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr class="border-b border-gray-800/50 hover:bg-gray-800/30 transition">
            <td class="px-4 py-3 text-white flex items-center gap-2">
              <% if user.avatar_url.present? %>
                <img src="<%= user.avatar_url %>" class="w-6 h-6 rounded-full">
              <% end %>
              <%= user.name %>
            </td>
            <td class="px-4 py-3 text-gray-400"><%= user.email %></td>
            <td class="px-4 py-3">
              <span class="text-xs px-2 py-0.5 rounded-full font-medium
                <%= case user.role
                    when 'admin'    then 'bg-red-900 text-red-300'
                    when 'operator' then 'bg-blue-900 text-blue-300'
                    when 'reviewer' then 'bg-yellow-900 text-yellow-300'
                    else                 'bg-gray-800 text-gray-400'
                    end %>">
                <%= user.role %>
              </span>
            </td>
            <td class="px-4 py-3 text-gray-500"><%= user.created_at.strftime("%b %d, %Y") %></td>
            <td class="px-4 py-3">
              <%= link_to "Edit", edit_admin_user_path(user), class: "text-blue-400 hover:text-blue-300 text-xs" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
