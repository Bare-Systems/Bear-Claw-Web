<% content_for :title, "Admin — BearClaw" %>

<div class="max-w-5xl mx-auto">
  <h1 class="text-2xl font-bold text-white mb-1">Admin</h1>
  <p class="text-gray-500 text-sm mb-8">System administration</p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <%= link_to admin_users_path, class: "bg-gray-900 border border-gray-800 rounded-lg p-5 hover:border-gray-600 transition" do %>
      <h2 class="text-white font-semibold mb-1">Users</h2>
      <p class="text-gray-500 text-sm">Manage user accounts and roles</p>
    <% end %>
    <%= link_to admin_settings_path, class: "bg-gray-900 border border-gray-800 rounded-lg p-5 hover:border-gray-600 transition" do %>
      <h2 class="text-white font-semibold mb-1">Settings</h2>
      <p class="text-gray-500 text-sm">Service tokens and configuration</p>
    <% end %>
    <%= link_to admin_audit_path, class: "bg-gray-900 border border-gray-800 rounded-lg p-5 hover:border-gray-600 transition" do %>
      <h2 class="text-white font-semibold mb-1">Audit Log</h2>
      <p class="text-gray-500 text-sm">Platform-level access and change history</p>
    <% end %>
  </div>
</div>
