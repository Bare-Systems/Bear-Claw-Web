<% content_for :title, "Invites — Admin — BearClaw" %>

<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold text-white mb-6">Invites</h1>

  <% if notice.present? %>
    <div class="mb-6 bg-green-900/50 border border-green-700 rounded-lg px-4 py-3 text-green-300 text-sm break-all">
      <%= notice %>
    </div>
  <% end %>

  <div class="bg-gray-900 border border-gray-800 rounded-lg p-6 mb-8">
    <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-4">Generate Invite Link</h2>

    <%= form_with url: admin_invites_path, method: :post, data: { turbo: false } do |f| %>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-3 mb-4">
        <div>
          <%= f.label :email, "Email (optional)", class: "block text-xs text-gray-500 mb-1" %>
          <%= f.email_field :email,
              placeholder: "any@email.com",
              class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white placeholder-gray-600 focus:outline-none focus:border-blue-500" %>
        </div>
        <div>
          <%= f.label :expires_in_days, "Expires in days (blank = never)", class: "block text-xs text-gray-500 mb-1" %>
          <%= f.number_field :expires_in_days,
              min: 1,
              placeholder: "never",
              class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white placeholder-gray-600 focus:outline-none focus:border-blue-500" %>
        </div>
        <div>
          <%= f.label :max_uses, "Max uses", class: "block text-xs text-gray-500 mb-1" %>
          <%= f.number_field :max_uses,
              min: 1,
              value: 1,
              class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white placeholder-gray-600 focus:outline-none focus:border-blue-500" %>
        </div>
      </div>
      <%= f.submit "Generate Invite Link",
          class: "bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition cursor-pointer" %>
    <% end %>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-lg overflow-hidden">
    <table class="w-full text-sm">
      <thead class="border-b border-gray-800">
        <tr class="text-gray-500 text-left">
          <th class="px-4 py-3 font-medium">Email</th>
          <th class="px-4 py-3 font-medium">Status</th>
          <th class="px-4 py-3 font-medium">Created by</th>
          <th class="px-4 py-3 font-medium">Accepted by</th>
          <th class="px-4 py-3 font-medium">Expires</th>
          <th class="px-4 py-3 font-medium">Uses</th>
          <th class="px-4 py-3 font-medium"></th>
        </tr>
      </thead>
      <tbody>
        <% @invites.each do |invite| %>
          <tr class="border-b border-gray-800/50 hover:bg-gray-800/30 transition">
            <td class="px-4 py-3 text-white"><%= invite.email.presence || "Any" %></td>
            <td class="px-4 py-3">
              <span class="text-xs px-2 py-0.5 rounded-full font-medium
                <%= case invite.status
                    when "pending"  then "bg-yellow-900 text-yellow-300"
                    when "accepted" then "bg-green-900 text-green-300"
                    when "revoked"  then "bg-red-900 text-red-300"
                    else                 "bg-gray-800 text-gray-400"
                    end %>">
                <%= invite.status %>
              </span>
            </td>
            <td class="px-4 py-3 text-gray-400"><%= invite.created_by&.name %></td>
            <td class="px-4 py-3 text-gray-400"><%= invite.accepted_by&.name.presence || "—" %></td>
            <td class="px-4 py-3 text-gray-500">
              <%= invite.expires_at ? invite.expires_at.strftime("%b %d, %Y") : "Never" %>
            </td>
            <td class="px-4 py-3 text-gray-400"><%= invite.use_count %> / <%= invite.max_uses %></td>
            <td class="px-4 py-3">
              <% if invite.status == "pending" %>
                <%= button_to "Revoke",
                    admin_invite_path(invite),
                    method: :delete,
                    data: { turbo: false, confirm: "Revoke this invite?" },
                    class: "text-red-400 hover:text-red-300 text-xs cursor-pointer bg-transparent border-0 p-0" %>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @invites.empty? %>
          <tr>
            <td colspan="7" class="px-4 py-6 text-center text-gray-600 text-sm">No invites yet.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
